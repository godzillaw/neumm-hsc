{
  "redirects": [
    { "source": "/", "destination": "/math-nsw/app", "permanent": false }
  ],
  "rewrites": [
    { "source": "/math-nsw",       "destination": "https://hsc-math-marketing.vercel.app/math-nsw" },
    { "source": "/math-nsw/:path*", "destination": "https://hsc-math-marketing.vercel.app/math-nsw/:path*" }
  ],
  "crons": [
    {
      "path": "/api/cron/streak-check",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/clm-aggregate",
      "schedule": "0 16 * * *"
    }
  ]
}
